<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Car image -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImg"
            android:layout_width="110dp"
            android:layout_height="82dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgCar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/car1" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Name -->
        <TextView
            android:id="@+id/tvCar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/sample_car_name"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cardImg"
            app:layout_constraintTop_toTopOf="@id/cardImg"
            android:layout_marginEnd="12dp" />

        <!-- Status badge -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="@string/status_active"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_badge_available"
            app:layout_constraintStart_toStartOf="@id/tvCar"
            app:layout_constraintTop_toBottomOf="@id/tvCar" />

        <!-- Date -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/sample_booking_dates"
            android:textColor="?android:textColorSecondary"
            app:layout_constraintStart_toStartOf="@id/tvCar"
            app:layout_constraintEnd_toStartOf="@id/cardImg"
            app:layout_constraintTop_toBottomOf="@id/tvStatus"
            android:layout_marginEnd="12dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Price -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/sample_price"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tvCar"
            app:layout_constraintTop_toBottomOf="@id/tvDate" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="90dp"
            android:layout_height="34dp"
            android:text="@string/cancel"
            android:textAllCaps="false"
            app:cornerRadius="18dp"
            app:backgroundTint="#C62828"
            android:textColor="@android:color/white"

            app:layout_constraintStart_toStartOf="@id/tvCar"
            app:layout_constraintTop_toBottomOf="@id/tvPrice"
            android:layout_marginTop="12dp"

            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="2dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>