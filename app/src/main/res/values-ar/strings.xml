    <string name="desc_corolla">سيارة اقتصادية عملية بقيادة سلسة وموثوقية عالية، مناسبة للمدينة والرحلات.</string>
    <string name="fuel_corolla">استهلاك الوقود: ~6.5 لتر/100كم</string>

    <string name="desc_bmw_x5">سيارة SUV فاخرة بأداء قوي ومساحة واسعة وميزات أمان متقدمة، مناسبة للعائلة.</string>
    <string name="fuel_bmw_x5">استهلاك الوقود: ~9.5 لتر/100كم</string>

    <string name="desc_mercedes_c200">سيارة سيدان فاخرة براحة عالية وتجربة قيادة سلسة، مناسبة للأعمال والراحة.</string>
    <string name="fuel_mercedes_c200">استهلاك الوقود: ~7.4 لتر/100كم</string>

    <string name="desc_tesla_model3">سيارة كهربائية حديثة بتسارع قوي وتقنيات ذكية وقيادة هادئة.</string>
    <string name="fuel_tesla_model3">استهلاك الطاقة: ~15 ك.و.س/100كم</string>

    <!-- Economy -->
    <string name="desc_hyundai_i10">سيارة صغيرة للمدينة سهلة القيادة والاصطفاف، ممتازة للاستخدام اليومي.</string>
    <string name="fuel_hyundai_i10">استهلاك الوقود: ~5.5 لتر/100كم</string>

    <string name="desc_kia_rio">سيارة اقتصادية بمستوى راحة جيد وقيادة سلسة.</string>
    <string name="fuel_kia_rio">استهلاك الوقود: ~6.0 لتر/100كم</string>

    <!-- SUV -->
    <string name="desc_land_cruiser">سيارة SUV قوية بمساحة وراحة ممتازة، مناسبة للعائلات والرحلات.</string>
    <string name="fuel_land_cruiser">استهلاك الوقود: ~12.0 لتر/100كم</string>

    <string name="desc_nissan_x_trail">SUV عملية بمساحة جيدة وكفاءة مناسبة للاستخدام اليومي.</string>
    <string name="fuel_nissan_x_trail">استهلاك الوقود: ~8.5 لتر/100كم</string>

    <!-- Luxury -->
    <string name="desc_bmw_520i">سيارة سيدان فاخرة بأداء سلس وداخلية راقية.</string>
    <string name="fuel_bmw_520i">استهلاك الوقود: ~7.8 لتر/100كم</string>

    <string name="desc_audi_a6">سيدان فاخرة مريحة بتقنيات حديثة وتجربة قيادة راقية.</string>
    <string name="fuel_audi_a6">استهلاك الوقود: ~8.2 لتر/100كم</string>

    <!-- Sport -->
    <string name="desc_ford_mustang">سيارة رياضية كلاسيكية بتسارع قوي وتجربة قيادة ممتعة.</string>
    <string name="fuel_ford_mustang">استهلاك الوقود: ~10.5 لتر/100كم</string>

    <string name="desc_chevrolet_camaro">كوبيه رياضية بأداء قوي وتصميم جريء.</string>
    <string name="fuel_chevrolet_camaro">استهلاك الوقود: ~11.0 لتر/100كم</string>

    <string name="desc_porsche_911">سيارة رياضية أيقونية بأداء وتحكم ممتازين.</string>
    <string name="fuel_porsche_911">استهلاك الوقود: ~10.0 لتر/100كم</string>

